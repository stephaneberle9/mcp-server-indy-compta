# Indy.fr MCP server — environment configuration
# Copy to .env and fill in as needed.

# ---------------------------------------------------------------------------
# Option A: static token (fastest, no browser required)
# ---------------------------------------------------------------------------
# Capture the Indy.fr HS512 JWT from your browser:
#   1. Log in at https://app.indy.fr
#   2. Open DevTools (F12) → Network → reload (F5)
#   3. Click any request to app.indy.fr/api/ → Headers
#   4. Copy the value AFTER "Bearer " in the Authorization header
# INDY_TOKEN=your-hs512-jwt-here

# ---------------------------------------------------------------------------
# Option B: browser auth (automatic, no manual token capture needed)
# ---------------------------------------------------------------------------
# Leave INDY_TOKEN unset. On the first tool call the server will:
#   1. Open a browser window navigating to https://app.indy.fr
#   2. Wait for you to complete the Firebase email-OTP login
#   3. Capture the Indy.fr HS512 JWT from the first authenticated request
#   4. Persist the token to ~/.cache/mcp-server-indy-compta/token.json
# Subsequent starts reuse the cached token; the browser only reopens on 401.
#
# Which browser to drive (optional; default: chrome). The login flow reuses
# the browser's existing profile, so the chosen browser must be installed.
# Set this to "edge" if Chrome isn't installed — Edge ships with Windows.
# Values: chrome | edge | chromium
# INDY_BROWSER=edge
#
# Override the cache file location (optional):
# INDY_TOKEN_CACHE_PATH=/path/to/token.json

# ---------------------------------------------------------------------------
# Debug logging
# ---------------------------------------------------------------------------
# INDY_COMPTA_DEBUG=true
